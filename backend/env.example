# Environment Configuration for CarbonCapture Backend
FLASK_DEBUG=False
PORT=5001

# REQUIRED in production. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# Only set ALLOW_INSECURE_DEV=true for local development if JWT_SECRET_KEY
# is unset. The server refuses to start without one of these in production.
ALLOW_INSECURE_DEV=false

# Comma-separated list of allowed CORS origins. Leave empty to default to
# local-dev origins (localhost:3000, localhost:5173, 127.0.0.1:3000).
# In production set explicitly, e.g. CORS_ORIGINS=https://carbonflow.net
CORS_ORIGINS=

# Azure OpenAI Configuration (optional - app will work without it)
AZURE_OPENAI_ENDPOINT=your-azure-openai-endpoint
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# Database Configuration
DATABASE_FILE=database.json

# Vector System Configuration
VECTOR_CACHE_DIR=./vectors

# Railway specific (leave empty, Railway will set PORT automatically)
# PORT will be set by Railway deployment automatically
